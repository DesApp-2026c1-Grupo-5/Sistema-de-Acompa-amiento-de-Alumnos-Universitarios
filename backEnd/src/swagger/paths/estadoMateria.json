{
  "/api/materias/{id}/inscribir": {
    "post": {
      "tags": ["Estados de Materia"],
      "summary": "Inscribirse a una materia",
      "description": "Inscribe al estudiante autenticado en una materia. Crea un registro de estado de materia con estado 'cursando'.",
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" },
          "description": "ID de la materia"
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "anio": { "type": ["integer", "null"], "description": "Año de cursada" },
                "cuatrimestre": { "type": ["integer", "null"], "enum": [1, 2], "description": "Cuatrimestre" },
                "nota": { "type": ["number", "null"], "minimum": 0, "maximum": 10 },
                "fecha": { "type": ["string", "null"], "format": "date" }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Inscripción exitosa",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ok": { "type": "boolean", "example": true },
                  "data": { "description": "Resultado de la acción académica" }
                }
              }
            }
          }
        }
      }
    }
  },
