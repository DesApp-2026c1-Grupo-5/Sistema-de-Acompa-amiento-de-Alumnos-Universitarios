                "cuatrimestre": { "type": ["integer", "null"], "enum": [1, 2] },
                "nota": { "type": ["number", "null"], "minimum": 0, "maximum": 10 },
                "fecha": { "type": ["string", "null"], "format": "date" }
              }
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Regularización exitosa",
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "ok": { "type": "boolean", "example": true },
                  "data": { "description": "Resultado de la acción académica" }
                }
              }
            }
          }
